<%- include('partials/head', { title: task.title }) %>

<%
  const priorityColors = { high: '#FF5C7A', medium: '#FFB347', low: '#00F5A0' };
  const priorityLabels = { high: 'HIGH', medium: 'MEDIUM', low: 'LOW' };
  const statusLabels = { todo: 'To Do', inprogress: 'In Progress', review: 'In Review', done: 'Completed' };
  const statusColors = { todo: 'var(--text-muted)', inprogress: 'var(--cyan)', review: 'var(--amber)', done: 'var(--mint)' };
  const pColor = priorityColors[task.priority] || '#FFB347';
  const progressColor = task.progress === 100 ? '#00F5A0' : task.progress > 60 ? '#6C63FF' : '#FFB347';
  const tagColorMap = {};
  task.tags.forEach(tt => { tagColorMap[tt.tag.name] = tt.tag.color || '#6B6B8E'; });
  const avatarColors = ['#6C63FF', '#00D9FF', '#FF5C7A', '#00F5A0', '#FFB347'];
%>

<div class="app-layout">
  <%- include('partials/sidebar') %>

  <main class="main-content">
    <div class="topbar">
      <button class="mobile-menu-btn" onclick="toggleSidebar()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-left">
        <div class="breadcrumb">
          <a href="/dashboard/<%= task.project.id %>-<%= task.project.slug %>" class="breadcrumb-text breadcrumb-link">
            <%= task.project.name %>
          </a>
          <span class="breadcrumb-separator">/</span>
          <span class="breadcrumb-text"><%= task.title %></span>
        </div>
      </div>
      <div class="topbar-right">
        <button class="theme-toggle-btn" onclick="cycleTheme()" title="Toggle theme">
          <svg class="theme-icon theme-icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="theme-icon theme-icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="theme-icon theme-icon-system" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
        <% if (currentUser) { %>
          <button class="btn-delete" onclick="deleteTask(<%= task.id %>)">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            Delete
          </button>
        <% } else { %>
          <a href="/auth/login" class="btn-new-task no-decoration">Login</a>
        <% } %>
      </div>
    </div>

    <div class="dashboard-body">
      <div class="task-detail">
        <div class="task-detail-main">
          <!-- Editable Title -->
          <% if (canEdit) { %>
            <input type="text" id="detailTitle" class="task-detail-title-input" value="<%= task.title %>" data-task-id="<%= task.id %>">
          <% } else { %>
            <h1 class="task-detail-title"><%= task.title %></h1>
          <% } %>

          <!-- Description -->
          <div class="task-detail-section">
            <h3 class="task-detail-label">DESCRIPTION</h3>
            <% if (canEdit) { %>
              <div id="descriptionRendered" class="task-detail-desc-rendered" title="Click to edit">
                <% if (task.description) { %>
                  <span class="desc-placeholder-loading">Loading...</span>
                <% } else { %>
                  <span class="desc-placeholder">Click to add description...</span>
                <% } %>
              </div>
              <div id="descriptionEditorWrap" class="task-detail-editor-wrap hidden">
                <textarea id="descriptionEditor"><%= task.description || '' %></textarea>
                <div class="editor-actions">
                  <button type="button" class="btn-editor-save" onclick="saveDescription()">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Save
                  </button>
                  <button type="button" class="btn-editor-cancel" onclick="cancelDescription()">Cancel</button>
                </div>
              </div>
            <% } else { %>
              <% if (task.description) { %>
                <div id="descriptionRendered" class="task-detail-desc-rendered">
                  <span class="desc-placeholder-loading">Loading...</span>
                </div>
              <% } else { %>
                <p class="task-detail-text" style="color: var(--text-dim);">No description</p>
              <% } %>
            <% } %>
          </div>

          <% if (task.tags.length > 0) { %>
            <div class="task-detail-section">
              <h3 class="task-detail-label">TAGS</h3>
              <div class="task-tags mt-6">
                <% task.tags.forEach(tt => { %>
                  <% const tColor = tagColorMap[tt.tag.name] || '#6B6B8E'; %>
                  <span class="tag-badge" style="background:<%= tColor %>18; border:1px solid <%= tColor %>35; color:<%= tColor %>;">
                    <%= tt.tag.name.charAt(0).toUpperCase() + tt.tag.name.slice(1) %>
                  </span>
                <% }) %>
              </div>
            </div>
          <% } %>

          <% if (task.assignees.length > 0) { %>
            <div class="task-detail-section">
              <h3 class="task-detail-label">ASSIGNEES</h3>
              <div class="flex gap-8 mt-6">
                <% task.assignees.forEach((a, i) => { %>
                  <% const aColor = avatarColors[i % avatarColors.length]; %>
                  <div class="assignee-chip">
                    <div class="avatar" style="background: <%= aColor %>22; border-color: <%= aColor %>55; color: <%= aColor %>; width:24px; height:24px; font-size:0.6rem;">
                      <%= a.user.name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() %>
                    </div>
                    <span class="assignee-chip-name"><%= a.user.name %></span>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>

          <!-- Subtasks -->
          <div class="task-detail-section">
            <div class="subtask-header">
              <h3 class="task-detail-label">SUBTASKS</h3>
              <% if (task.subtasks.length > 0) { %>
                <span class="subtask-count-badge"><%= task.subtasks.filter(s => s.done).length %>/<%= task.subtasks.length %></span>
              <% } %>
            </div>
            <% if (task.subtasks.length > 0) { %>
              <div class="subtask-progress-bar mt-6 mb-10">
                <% const dtDone = task.subtasks.filter(s => s.done).length; %>
                <% const dtPercent = task.status === 'done' ? 100 : Math.round(dtDone / (task.subtasks.length + 1) * 100); %>
                <div class="subtask-progress-fill" style="width:<%= dtPercent %>%;"></div>
              </div>
            <% } %>
            <div id="detailSubtaskList" class="subtask-list" data-task-id="<%= task.id %>" data-task-status="<%= task.status %>">
              <% task.subtasks.forEach(sub => { %>
                <div class="subtask-item <%= sub.done ? 'done' : '' %>" data-subtask-id="<%= sub.id %>">
                  <label class="subtask-check">
                    <input type="checkbox" <%= sub.done ? 'checked' : '' %> onchange="toggleDetailSubtask(<%= sub.id %>, this.checked)">
                    <span class="subtask-checkmark"></span>
                  </label>
                  <span class="subtask-title"><%= sub.title %></span>
                  <% if (currentUser) { %>
                    <button class="subtask-delete-btn" onclick="deleteDetailSubtask(<%= sub.id %>)">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <% if (currentUser) { %>
              <div class="subtask-add mt-8">
                <input type="text" id="detailSubtaskInput" class="subtask-input" placeholder="Add a subtask..." onkeydown="if(event.key==='Enter'){addDetailSubtask(); event.preventDefault();}">
                <button class="subtask-add-btn" onclick="addDetailSubtask()">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </div>
            <% } %>
          </div>
        </div>

        <div class="task-detail-sidebar">
          <div class="task-detail-meta-card">
            <% if (canEdit) { %>
              <div class="task-detail-meta-item">
                <span class="task-detail-label">STATUS</span>
                <select id="detailStatusSelect" class="detail-inline-select" data-task-id="<%= task.id %>">
                  <option value="todo" <%= task.status === 'todo' ? 'selected' : '' %>>To Do</option>
                  <option value="inprogress" <%= task.status === 'inprogress' ? 'selected' : '' %>>In Progress</option>
                  <option value="review" <%= task.status === 'review' ? 'selected' : '' %>>In Review</option>
                  <option value="done" <%= task.status === 'done' ? 'selected' : '' %>>Completed</option>
                </select>
              </div>
              <div class="task-detail-meta-item">
                <span class="task-detail-label">PRIORITY</span>
                <select id="detailPrioritySelect" class="detail-inline-select" data-task-id="<%= task.id %>">
                  <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>>Low</option>
                  <option value="medium" <%= task.priority === 'medium' ? 'selected' : '' %>>Medium</option>
                  <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>>High</option>
                </select>
              </div>
              <div class="task-detail-meta-item">
                <span class="task-detail-label">DUE DATE</span>
                <input type="date" id="detailDueDate" class="detail-inline-input" value="<%= task.dueDate || '' %>" data-task-id="<%= task.id %>">
              </div>
            <% } else { %>
              <div class="task-detail-meta-item">
                <span class="task-detail-label">STATUS</span>
                <span class="task-detail-meta-value" style="color:<%= statusColors[task.status] %>;">
                  <%= statusLabels[task.status] %>
                </span>
              </div>
              <div class="task-detail-meta-item">
                <span class="task-detail-label">PRIORITY</span>
                <span class="task-detail-meta-value" style="color:<%= pColor %>;">
                  <%= priorityLabels[task.priority] %>
                </span>
              </div>
              <% if (task.dueDate) { %>
                <div class="task-detail-meta-item">
                  <span class="task-detail-label">DUE DATE</span>
                  <span class="task-detail-meta-value"><%= task.dueDate %></span>
                </div>
              <% } %>
            <% } %>
            <div class="task-detail-meta-item">
              <span class="task-detail-label">PROGRESS</span>
              <div class="progress-inline">
                <div class="task-progress-track" style="flex:1;">
                  <div class="task-progress-fill" style="width:<%= task.progress %>%; background:<%= progressColor %>;"></div>
                </div>
                <span class="progress-value" style="color:<%= progressColor %>;"><%= task.progress %>%</span>
              </div>
            </div>
            <div class="task-detail-meta-item">
              <span class="task-detail-label">CREATED</span>
              <span class="task-detail-meta-value text-sm">
                <%= new Date(task.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('partials/modals/task-modal') %>
<%- include('partials/modals/delete-modal') %>

<script>
  window.TASK_DATA = {
    id: <%= task.id %>,
    projectId: <%= task.projectId %>,
    description: <%- JSON.stringify(task.description || '').replace(/<\//g, '<\\/').replace(/<!--/g, '<\\!--') %>,
    canEdit: <%= canEdit %>
  };
</script>
<%- include('partials/foot') %>

<script src="/js/modal.js"></script>
<script src="/js/subtask.js"></script>
<script src="/js/task-detail.js"></script>
<script>
  // Override delete redirect to go back to project
  const origConfirmDelete = confirmDelete;
  confirmDelete = async function() {
    const taskId = document.getElementById('deleteTaskId').value;
    try {
      await fetch('/api/tasks/' + taskId, { method: 'DELETE' });
      window.location.href = '/dashboard/' + <%- JSON.stringify(task.project.id + '-' + task.project.slug) %>;
    } catch (err) {
      console.error('Failed to delete task:', err);
    }
  };
</script>
