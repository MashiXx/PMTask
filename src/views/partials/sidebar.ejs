<div class="sidebar-overlay" onclick="toggleSidebar()"></div>
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-icon">&#10024;</div>
    <span class="sidebar-logo-text">PMTask</span>
  </div>

  <% if (typeof activeProject !== 'undefined' && activeProject) { %>
    <div class="sidebar-active-project">
      <a href="/projects" class="sidebar-project-link" title="Switch project">
        <span class="project-dot" style="background:<%= activeProject.color %>; box-shadow: 0 0 6px <%= activeProject.color %>55;"></span>
        <span class="sidebar-project-name"><%= activeProject.name %></span>
        <svg class="sidebar-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  <% } %>

  <% if (typeof activeProjectId !== 'undefined' && activeProjectId) { %>
    <!-- Group By -->
    <div class="sidebar-section-group" style="padding: 0 12px;">
      <p class="sidebar-section-title mb-8">GROUP BY</p>
      <div class="sidebar-groupby-toggle">
        <button class="sidebar-groupby-btn active" data-group="status" onclick="setGroupBy('status')">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Status
        </button>
        <button class="sidebar-groupby-btn" data-group="tag" onclick="setGroupBy('tag')">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Tag
        </button>
      </div>
    </div>

    <!-- Hide Completed -->
    <div style="padding: 0 12px; margin-top: 12px;">
      <label class="sidebar-toggle-label" id="hideCompletedLabel">
        <span class="sidebar-toggle-switch">
          <input type="checkbox" id="hideCompletedCheck" onchange="toggleCompletedTasks()">
          <span class="sidebar-toggle-slider"></span>
        </span>
        <span class="sidebar-toggle-text">Hide completed</span>
      </label>
    </div>

    <!-- Filters: Tags (when grouping by status) -->
    <div class="sidebar-tags" id="sidebarTagFilters">
      <div class="flex-between mb-10">
        <p class="sidebar-section-title" style="margin:0">TAGS</p>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <button class="column-add-btn" onclick="openTagManager()" title="Manage Tags">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          </button>
        <% } %>
      </div>
      <% if (typeof projectTags !== 'undefined' && projectTags.length > 0) { %>
        <div class="sidebar-tags-list">
          <% projectTags.forEach(tag => { %>
            <button class="sidebar-tag-btn" data-tag-name="<%= tag.name %>" onclick="toggleTagFilter(this)">
              <span class="tag-dot" style="background:<%= tag.color %>;"></span>
              <span class="tag-name"><%= tag.name.charAt(0).toUpperCase() + tag.name.slice(1) %></span>
            </button>
          <% }) %>
        </div>
        <button class="sidebar-clear-filters hidden" onclick="clearAllFilters()">Clear filters</button>
      <% } else { %>
        <p class="sidebar-no-tags">No tags yet</p>
      <% } %>
    </div>

    <!-- Filters: Status (when grouping by tag) -->
    <div class="sidebar-tags hidden" id="sidebarStatusFilters">
      <div class="flex-between mb-10">
        <p class="sidebar-section-title" style="margin:0">STATUS</p>
      </div>
      <div class="sidebar-tags-list">
        <button class="sidebar-tag-btn" data-status-name="todo" onclick="toggleStatusFilter(this)">
          <span class="tag-dot" style="background:#6B6B8E;"></span>
          <span class="tag-name">To Do</span>
        </button>
        <button class="sidebar-tag-btn" data-status-name="inprogress" onclick="toggleStatusFilter(this)">
          <span class="tag-dot" style="background:#6C63FF;"></span>
          <span class="tag-name">In Progress</span>
        </button>
        <button class="sidebar-tag-btn" data-status-name="review" onclick="toggleStatusFilter(this)">
          <span class="tag-dot" style="background:#FF5C7A;"></span>
          <span class="tag-name">In Review</span>
        </button>
        <button class="sidebar-tag-btn" data-status-name="done" onclick="toggleStatusFilter(this)">
          <span class="tag-dot" style="background:#00F5A0;"></span>
          <span class="tag-name">Completed</span>
        </button>
      </div>
      <button class="sidebar-clear-filters hidden" onclick="clearAllFilters()">Clear filters</button>
    </div>
  <% } %>

  <% if (typeof activeProjectId !== 'undefined' && activeProjectId) { %>
    <nav class="sidebar-admin-nav" style="border-top: 1px solid var(--border); margin-top: 8px; padding-top: 8px;">
      <a href="/dashboard?project=<%= activeProject.id %>-<%= activeProject.slug %>" class="nav-btn <%= typeof activePage === 'undefined' || activePage !== 'documents' ? 'active' : '' %>">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Tasks
      </a>
      <% if (currentUser || (typeof activeProject !== 'undefined' && activeProject && activeProject.publicDocuments)) { %>
      <a href="/projects/<%= activeProject.id %>-<%= activeProject.slug %>/documents" class="nav-btn <%= typeof activePage !== 'undefined' && activePage === 'documents' ? 'active' : '' %>">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        Documents
      </a>
      <% } %>
      <% if (currentUser && currentUser.role === 'admin') { %>
      <a href="/projects" class="nav-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Projects
      </a>
      <a href="/admin/users" class="nav-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Users
      </a>
      <% } %>
    </nav>
  <% } %>

  <% if (currentUser) { %>
    <div class="sidebar-user">
      <a href="/profile" class="sidebar-avatar no-decoration" title="Profile"><%= currentUser.name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() %></a>
      <div class="sidebar-user-info">
        <a href="/profile" class="no-decoration"><p class="sidebar-user-name"><%= currentUser.name %></p></a>
        <p class="sidebar-user-role"><%= currentUser.role === 'admin' ? 'Admin' : 'Developer' %></p>
      </div>
      <a href="/auth/logout" class="sidebar-settings" title="Logout">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  <% } else { %>
    <div class="sidebar-user">
      <a href="/auth/login" class="btn-new-task" style="width:100%; justify-content:center;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Login
      </a>
    </div>
  <% } %>
</aside>
