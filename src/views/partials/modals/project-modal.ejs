<div class="modal-overlay" id="projectModal">
  <div class="modal">
    <h2 class="modal-title" id="projectModalTitle">New Project</h2>

    <form id="projectForm">
      <input type="hidden" id="projectId" value="">

      <div class="form-group">
        <label>PROJECT NAME</label>
        <input type="text" id="projectName" placeholder="Enter project name" required>
      </div>

      <div class="form-group">
        <label>COLOR</label>
        <div class="color-swatch-wrap">
          <% ['#6C63FF','#00D9FF','#00F5A0','#FF5C7A','#FFB347','#E8E8FF'].forEach((c, i) => { %>
            <label class="color-swatch-label">
              <input type="radio" name="projectColor" value="<%= c %>" class="color-swatch-radio" <%= i === 0 ? 'checked' : '' %>>
              <span class="color-swatch" data-color="<%= c %>" style="
                display:block; width:28px; height:28px; border-radius:8px;
                background:<%= c %>; border:2px solid transparent;
                transition:all 0.15s;
              "></span>
            </label>
          <% }) %>
        </div>
      </div>

      <% if (currentUser && currentUser.role === 'admin') { %>
      <div class="form-group" id="projectPublicSettings" style="display:none;">
        <label>PUBLIC ACCESS</label>
        <div style="display:flex; flex-direction:column; gap:10px; margin-top:4px;">
          <label class="toggle-label">
            <input type="checkbox" id="projectPublicTasks" class="toggle-input">
            <span class="toggle-switch"></span>
            <span class="toggle-text">Public Tasks <span style="color:var(--text-dim); font-size:0.7rem;">&mdash; anyone can view tasks</span></span>
          </label>
          <label class="toggle-label">
            <input type="checkbox" id="projectPublicDocuments" class="toggle-input">
            <span class="toggle-switch"></span>
            <span class="toggle-text">Public Documents <span style="color:var(--text-dim); font-size:0.7rem;">&mdash; anyone can view documents</span></span>
          </label>
        </div>
      </div>
      <% } %>

      <div class="modal-actions">
        <button type="button" class="btn-cancel" onclick="closeProjectModal()">Cancel</button>
        <button type="submit" class="btn-submit" id="projectSubmitBtn">Create Project</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="deleteProjectModal">
  <div class="modal text-center">
    <h2 class="modal-title">Delete Project</h2>
    <p class="modal-confirm-text mb-8">
      Delete <strong id="deleteProjectName" style="color:var(--text)"></strong>?
    </p>
    <p class="modal-warning-text mb-16">
      All tasks in this project will also be deleted. This action cannot be undone.
    </p>
    <div class="form-group text-left mb-20">
      <label>TYPE THE PROJECT NAME TO CONFIRM</label>
      <input type="text" id="deleteProjectConfirmInput" placeholder="Type project name here" autocomplete="off">
    </div>
    <input type="hidden" id="deleteProjectId" value="">
    <input type="hidden" id="deleteProjectExpectedName" value="">
    <div class="modal-actions justify-center">
      <button class="btn-cancel" onclick="closeDeleteProjectModal()">Cancel</button>
      <button class="btn-delete btn-disabled" id="deleteProjectBtn" onclick="confirmDeleteProject()" disabled>Delete</button>
    </div>
  </div>
</div>
