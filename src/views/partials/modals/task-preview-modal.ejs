<div class="modal-overlay" id="taskPreviewModal">
  <div class="modal modal-lg">
    <input type="hidden" id="previewTaskId" value="">

    <!-- Editable Title -->
    <div class="mb-12">
      <input type="text" id="previewTitle" class="preview-editable-title" placeholder="Task title">
    </div>

    <!-- Status + Priority row -->
    <div class="flex gap-8 mb-16">
      <select id="previewStatusSelect" class="preview-inline-select">
        <option value="todo">To Do</option>
        <option value="inprogress">In Progress</option>
        <option value="review">In Review</option>
        <option value="done">Completed</option>
      </select>
      <select id="previewPrioritySelect" class="preview-inline-select">
        <option value="low">Low</option>
        <option value="medium">Medium</option>
        <option value="high">High</option>
      </select>
    </div>

    <!-- Editable Description -->
    <div class="mb-16">
      <textarea id="previewDescription" class="preview-editable-desc" placeholder="Add a description..." rows="2"></textarea>
    </div>

    <div id="previewTagsWrap" class="mb-16">
      <div class="preview-tags-header">
        <p class="label-meta" style="margin:0">Tags</p>
        <button type="button" class="preview-tag-toggle-btn preview-auth-btn" onclick="event.stopPropagation(); togglePreviewTagEditor()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
      <div id="previewTags" class="task-tags"></div>
      <div id="previewTagEditor" class="preview-tag-editor hidden" onclick="event.stopPropagation()">
        <div id="previewTagOptions" class="preview-tag-options"></div>
      </div>
    </div>

    <div class="flex gap-16 mb-16">
      <div id="previewDueDateWrap" class="hidden">
        <p class="label-meta">Due Date</p>
        <p id="previewDueDate" class="progress-value"></p>
      </div>
      <div>
        <p class="label-meta">Progress</p>
        <div class="progress-inline">
          <div class="task-progress-track" style="width:100px;">
            <div class="task-progress-fill" id="previewProgressBar"></div>
          </div>
          <span id="previewProgressText" class="progress-value"></span>
        </div>
      </div>
    </div>

    <div id="previewAssigneesWrap" class="mb-16 hidden">
      <p class="label-meta">Assignees</p>
      <div id="previewAssignees" class="flex gap-6"></div>
    </div>

    <!-- Subtasks -->
    <div class="mb-20">
      <div class="subtask-header">
        <p class="label-meta">Subtasks <span id="previewSubtaskCount" class="subtask-count-badge"></span></p>
      </div>
      <div id="previewSubtaskList" class="subtask-list"></div>
      <div id="previewSubtaskAdd" class="subtask-add hidden">
        <input type="text" id="previewSubtaskInput" class="subtask-input" placeholder="Add a subtask..." onkeydown="if(event.key==='Enter'){addPreviewSubtask(); event.preventDefault();}">
        <button class="subtask-add-btn" onclick="addPreviewSubtask()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
    </div>

    <div class="modal-actions">
      <button type="button" class="btn-cancel" onclick="closeTaskPreview()">Close</button>
      <div class="flex gap-8">
        <button type="button" class="btn-delete preview-auth-btn" onclick="previewDelete()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          Delete
        </button>
        <button type="button" class="btn-cancel preview-auth-btn" onclick="previewEdit()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Edit
        </button>
        <a id="previewDetailsLink" href="#" class="btn-submit no-decoration text-center">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          Expand
        </a>
      </div>
    </div>
  </div>
</div>
