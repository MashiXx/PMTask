<div class="modal-overlay" id="taskPreviewModal">
  <div class="modal modal-lg">
    <input type="hidden" id="previewTaskId" value="">

    <!-- Editable Title -->
    <div class="mb-12">
      <input type="text" id="previewTitle" class="preview-editable-title" placeholder="Task title">
    </div>

    <!-- Status + Priority row -->
    <div class="flex gap-8 mb-16">
      <select id="previewStatusSelect" class="preview-inline-select">
        <option value="todo">To Do</option>
        <option value="inprogress">In Progress</option>
        <option value="review">In Review</option>
        <option value="done">Completed</option>
      </select>
      <select id="previewPrioritySelect" class="preview-inline-select">
        <option value="low">Low</option>
        <option value="medium">Medium</option>
        <option value="high">High</option>
      </select>
    </div>

    <!-- Editable Description -->
    <div class="mb-16">
      <textarea id="previewDescription" class="preview-editable-desc" placeholder="Add a description..." rows="2"></textarea>
    </div>

    <div id="previewTagsWrap" class="mb-16 hidden">
      <p class="label-meta">Tags</p>
      <div id="previewTags" class="task-tags"></div>
    </div>

    <div class="flex gap-16 mb-16">
      <div id="previewDueDateWrap" class="hidden">
        <p class="label-meta">Due Date</p>
        <p id="previewDueDate" class="progress-value"></p>
      </div>
      <div>
        <p class="label-meta">Progress</p>
        <div class="progress-inline">
          <div class="task-progress-track" style="width:100px;">
            <div class="task-progress-fill" id="previewProgressBar"></div>
          </div>
          <span id="previewProgressText" class="progress-value"></span>
        </div>
      </div>
    </div>

    <div id="previewAssigneesWrap" class="mb-20 hidden">
      <p class="label-meta">Assignees</p>
      <div id="previewAssignees" class="flex gap-6"></div>
    </div>

    <div class="modal-actions">
      <button type="button" class="btn-cancel" onclick="closeTaskPreview()">Close</button>
      <div class="flex gap-8">
        <button type="button" class="btn-delete" onclick="previewDelete()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          Delete
        </button>
        <a id="previewDetailsLink" href="#" class="btn-submit no-decoration text-center">
          Details
        </a>
      </div>
    </div>
  </div>
</div>
