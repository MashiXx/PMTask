<%- include('partials/head', { title: 'Projects' }) %>

<div class="app-layout">
  <%- include('partials/sidebar') %>

  <main class="main-content">
    <div class="topbar">
      <button class="mobile-menu-btn" onclick="toggleSidebar()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-left">
        <div class="breadcrumb">
          <span class="breadcrumb-text">Projects</span>
        </div>
      </div>
      <div class="topbar-right">
        <button class="btn-new-task" onclick="openProjectModal()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          New Project
        </button>
      </div>
    </div>

    <div class="dashboard-body">
      <div class="projects-grid">
        <% projects.forEach(p => { %>
          <a href="/dashboard?project=<%= p.id %>" class="project-card no-decoration" style="border-left: 3px solid <%= p.color %>">
            <div class="project-card-header">
              <div style="display:flex; align-items:center; gap:10px;">
                <span class="project-dot" style="background: <%= p.color %>; box-shadow: 0 0 6px <%= p.color %>55; width:10px; height:10px;"></span>
                <span class="project-card-name"><%= p.name %></span>
              </div>
              <div class="project-card-actions" onclick="event.preventDefault(); event.stopPropagation();">
                <button class="column-add-btn" onclick="openProjectModal(<%= p.id %>, '<%= p.name.replace(/'/g, "\\'") %>', '<%= p.color %>')" title="Edit">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="column-add-btn text-coral" onclick="deleteProject(<%= p.id %>, '<%= p.name.replace(/'/g, "\\'") %>')" title="Delete">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </div>
            </div>
            <div class="project-card-stats">
              <div class="project-card-stat">
                <span class="project-card-stat-value"><%= p._count.tasks %></span>
                <span class="project-card-stat-label">Tasks</span>
              </div>
              <div class="project-card-stat">
                <span class="project-card-stat-value"><%= p.doneTasks %></span>
                <span class="project-card-stat-label">Done</span>
              </div>
              <div class="project-card-stat">
                <span class="project-card-stat-value"><%= p.overdueTasks %></span>
                <span class="project-card-stat-label">Overdue</span>
              </div>
            </div>
            <% const progress = p._count.tasks > 0 ? Math.round((p.doneTasks / p._count.tasks) * 100) : 0; %>
            <div class="task-progress" style="margin-top:8px;">
              <div class="task-progress-track">
                <div class="task-progress-fill" style="width: <%= progress %>%; background: <%= p.color %>;"></div>
              </div>
            </div>
            <p class="project-card-date">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Created <%= new Date(p.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </p>
          </a>
        <% }) %>

        <% if (projects.length === 0) { %>
          <div class="empty-state">
            <p>No projects yet.</p>
            <button class="btn-new-task mt-16" onclick="openProjectModal()">Create your first project</button>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<%- include('partials/modals/project-modal') %>

<script src="/js/project.js"></script>

<%- include('partials/foot') %>
