<%- include('partials/head', { title: 'Profile' }) %>

<div class="app-layout">
  <%- include('partials/sidebar') %>

  <main class="main-content">
    <div class="topbar">
      <button class="mobile-menu-btn" onclick="toggleSidebar()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-left">
        <div class="breadcrumb">
          <span class="breadcrumb-text">Profile</span>
        </div>
      </div>
      <div class="topbar-right">
        <button class="theme-toggle-btn" onclick="cycleTheme()" title="Toggle theme">
          <svg class="theme-icon theme-icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="theme-icon theme-icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="theme-icon theme-icon-system" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
      </div>
    </div>

    <div class="dashboard-body">
      <div class="profile-grid">
        <div class="profile-card">
          <div class="profile-avatar-large">
            <%= currentUser.name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() %>
          </div>
          <h2 class="profile-name"><%= currentUser.name %></h2>
          <p class="profile-email"><%= currentUser.email %></p>
          <% if (currentUser.googleId) { %>
            <span class="profile-badge">Google Account</span>
          <% } %>
        </div>

        <div class="profile-forms">
          <div class="profile-section theme-picker-section">
            <h3 class="profile-section-title">Theme</h3>
            <p style="color: var(--text-muted); font-size: 0.8125rem; margin-bottom: 8px;">Choose a theme for the interface</p>
            <div class="theme-picker-grid">
              <!-- System -->
              <div class="theme-picker-card <%= userTheme === 'system' ? 'active' : '' %>" data-theme="system" onclick="applyTheme('system')">
                <div class="theme-preview" style="background: linear-gradient(135deg, #1E1E2E 50%, #F8F8FC 50%);">
                  <div class="theme-preview-sidebar" style="background: linear-gradient(180deg, #252536 50%, #ECECF4 50%);"></div>
                  <div class="theme-preview-main" style="background: transparent;">
                    <div class="theme-preview-topbar" style="background: linear-gradient(90deg, #3B3B52 50%, #D4D4DE 50%);"></div>
                    <div class="theme-preview-columns">
                      <div class="theme-preview-col" style="background: linear-gradient(180deg, #2D2D40 50%, #FFFFFF 50%);"></div>
                      <div class="theme-preview-col" style="background: linear-gradient(180deg, #2D2D40 50%, #FFFFFF 50%);"></div>
                      <div class="theme-preview-col" style="background: linear-gradient(180deg, #2D2D40 50%, #FFFFFF 50%);"></div>
                    </div>
                  </div>
                </div>
                <div class="theme-picker-info">
                  <span class="theme-picker-name">System</span>
                  <span class="theme-picker-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                </div>
              </div>

              <!-- Light -->
              <div class="theme-picker-card <%= userTheme === 'light' ? 'active' : '' %>" data-theme="light" onclick="applyTheme('light')">
                <div class="theme-preview" style="background: #F8F8FC;">
                  <div class="theme-preview-sidebar" style="background: #ECECF4;"></div>
                  <div class="theme-preview-main" style="background: #F8F8FC;">
                    <div class="theme-preview-topbar" style="background: #D4D4DE;"></div>
                    <div class="theme-preview-columns">
                      <div class="theme-preview-col" style="background: #FFFFFF;"></div>
                      <div class="theme-preview-col" style="background: #FFFFFF;"></div>
                      <div class="theme-preview-col" style="background: #FFFFFF;"></div>
                    </div>
                  </div>
                </div>
                <div class="theme-picker-info">
                  <span class="theme-picker-name">Light</span>
                  <span class="theme-picker-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                </div>
              </div>

              <!-- Dark -->
              <div class="theme-picker-card <%= userTheme === 'dark' ? 'active' : '' %>" data-theme="dark" onclick="applyTheme('dark')">
                <div class="theme-preview" style="background: #1E1E2E;">
                  <div class="theme-preview-sidebar" style="background: #252536;"></div>
                  <div class="theme-preview-main" style="background: #1E1E2E;">
                    <div class="theme-preview-topbar" style="background: #3B3B52;"></div>
                    <div class="theme-preview-columns">
                      <div class="theme-preview-col" style="background: #2D2D40;"></div>
                      <div class="theme-preview-col" style="background: #2D2D40;"></div>
                      <div class="theme-preview-col" style="background: #2D2D40;"></div>
                    </div>
                  </div>
                </div>
                <div class="theme-picker-info">
                  <span class="theme-picker-name">Dark</span>
                  <span class="theme-picker-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                </div>
              </div>

              <!-- Vintage (Light) -->
              <div class="theme-picker-card <%= userTheme === 'vintage' ? 'active' : '' %>" data-theme="vintage" onclick="applyTheme('vintage')">
                <div class="theme-preview" style="background: #F2EBD9;">
                  <div class="theme-preview-sidebar" style="background: #E8E0CE;"></div>
                  <div class="theme-preview-main" style="background: #F2EBD9;">
                    <div class="theme-preview-topbar" style="background: #D4C9B5;"></div>
                    <div class="theme-preview-columns">
                      <div class="theme-preview-col" style="background: #E8DFF5;"></div>
                      <div class="theme-preview-col" style="background: #D5E5F5;"></div>
                      <div class="theme-preview-col" style="background: #F5D5DD;"></div>
                      <div class="theme-preview-col" style="background: #D5F0D0;"></div>
                    </div>
                  </div>
                </div>
                <div class="theme-picker-info">
                  <span class="theme-picker-name">Vintage</span>
                  <span class="theme-picker-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                </div>
              </div>

              <!-- Vintage Dark -->
              <div class="theme-picker-card <%= userTheme === 'vintage-dark' ? 'active' : '' %>" data-theme="vintage-dark" onclick="applyTheme('vintage-dark')">
                <div class="theme-preview" style="background: #1A1625;">
                  <div class="theme-preview-sidebar" style="background: #252036;"></div>
                  <div class="theme-preview-main" style="background: #1A1625;">
                    <div class="theme-preview-topbar" style="background: #3E3655;"></div>
                    <div class="theme-preview-columns">
                      <div class="theme-preview-col" style="background: rgba(108,80,180,0.25);"></div>
                      <div class="theme-preview-col" style="background: rgba(80,140,200,0.25);"></div>
                      <div class="theme-preview-col" style="background: rgba(200,100,120,0.25);"></div>
                      <div class="theme-preview-col" style="background: rgba(100,180,100,0.25);"></div>
                    </div>
                  </div>
                </div>
                <div class="theme-picker-info">
                  <span class="theme-picker-name">Vintage Dark</span>
                  <span class="theme-picker-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                </div>
              </div>
            </div>
          </div>

          <div class="profile-section">
            <h3 class="profile-section-title">Profile Information</h3>
            <form action="/profile/update" method="POST">
              <div class="form-group">
                <label>NAME</label>
                <input type="text" name="name" value="<%= currentUser.name %>" required>
              </div>
              <div class="form-group">
                <label>EMAIL</label>
                <input type="email" name="email" value="<%= currentUser.email %>" required>
              </div>
              <button type="submit" class="btn-submit" style="margin-top:8px;">Save Changes</button>
            </form>
          </div>

          <div class="profile-section">
            <h3 class="profile-section-title">Change Password</h3>
            <form action="/profile/password" method="POST">
              <% if (currentUser.password) { %>
                <div class="form-group">
                  <label>CURRENT PASSWORD</label>
                  <input type="password" name="currentPassword" placeholder="Enter current password" required>
                </div>
              <% } %>
              <div class="form-group">
                <label>NEW PASSWORD</label>
                <input type="password" name="newPassword" placeholder="Min 6 characters" required minlength="6">
              </div>
              <div class="form-group">
                <label>CONFIRM NEW PASSWORD</label>
                <input type="password" name="confirmPassword" placeholder="Re-enter new password" required minlength="6">
              </div>
              <button type="submit" class="btn-submit" style="margin-top:8px;">Change Password</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('partials/foot') %>
